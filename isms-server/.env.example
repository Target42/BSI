# Entwicklung (HTTP, unsicheres JWT erlaubt)
ENV=development
DATABASE_URL=postgres://ismsserver:ismsserver@localhost:5432/isms?sslmode=disable
HTTP_ADDR=:8080

# Pflicht in Produktion: mindestens 32 Zeichen, zufällig generieren
# Beispiel: openssl rand -base64 48
JWT_SECRET=dev-local-jwt-secret-change-in-production

# Token-Gültigkeit (z. B. 8h, 30m, 24h)
JWT_TTL=24h

# Optional: HTTPS (empfohlen außerhalb der lokalen Entwicklung)
# TLS_CERT_FILE=certs/server.crt
# TLS_KEY_FILE=certs/server.key

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_DISPLAY_NAME=Administrator

# IT-Grundschutz-Katalog: automatischer Import beim ersten Start, wenn DB leer ist.
# CATALOG_VERSION=2023
# CATALOG_XML_PATH=D:\RADStudio\Delphi\BSI\xml\XML_Kompendium_2023.xml

# Produktion (Beispiel):
# ENV=production
# JWT_SECRET=<mind. 32 Zeichen, zufällig>
# JWT_TTL=8h
# TLS_CERT_FILE=/etc/isms/server.crt
# TLS_KEY_FILE=/etc/isms/server.key
